<!DOCTYPE html>
<html>
<head>
    <title>True/False Game</title>

    <style>
        body {
            text-align: center;
            font-family: Arial;
        }

        button {
            padding: 10px 20px;
            margin: 5px;
            font-size: 16px;
        }
    </style>
</head>

<body>

<h1>WW2 True or False Game</h1>

<h2 id="question"></h2>

<button class="answer-btn" onclick="answer(true)">True</button>
<button class="answer-btn" onclick="answer(false)">False</button>

<p id="result"></p>
<p id="score"></p>

<button onclick="location.href='index.web'">Back to Home</button>
<br><br>
<button onclick="restartGame()">Restart</button>

<script>
let questions = [
    { text: "both atomic bombs used U235.", answer: false },
    { text: "the soviet allied with America before Germany.", answer: false },
    { text: "Nagasaki was bombed after Hiroshima.", answer: true },
    { text: "Oppenheimer was the discoverer of fission.", answer: false },
    { text: "Oppenheimer directed the Manhattan Project.", answer: false },
    { text: "Oppenheimer was German.", answer: false },
    { text: "Germany and the Soviet Union agreed to divide Poland.", answer: true },
    { text: "Germany succeeded in making an atomic bomb.", answer: false },
    { text: "Germany sent spies.", answer: false },
    { text: "Nagasaki was bombed first'.", answer: false },
    { text: "'Plutonium was a natural element.", answer: false }
];

let current = 0;
let score = 0;

// Shuffle function
function shuffle(array) {
    for (let i = array.length - 1; i > 0; i--) {
        let j = Math.floor(Math.random() * (i + 1));
        [array[i], array[j]] = [array[j], array[i]];
    }
}

// show question
function showQuestion() {
    document.getElementById("question").innerText = questions[current].text;
    document.getElementById("result").innerText = "";
}

// answer logic
function answer(userChoice) {
    if (userChoice === questions[current].answer) {
        document.getElementById("result").innerText = "Correct!";
        score++;
    } else {
        document.getElementById("result").innerText = "Wrong!";
    }

    current++;

    if (current < questions.length) {
        setTimeout(showQuestion, 800);
    } else {
        if (score === questions.length) {
            document.getElementById("question").innerText = "You Win!";
        } else {
            document.getElementById("question").innerText = "You Lose!";
        }

        document.getElementById("score").innerText =
            "Score: " + score + " / " + questions.length;

        document.querySelectorAll(".answer-btn").forEach(btn => btn.disabled = true);
    }
}

// restart function
function restartGame() {
    current = 0;
    score = 0;

    shuffle(questions);

    document.getElementById("score").innerText = "";
    document.querySelectorAll(".answer-btn").forEach(btn => btn.disabled = false);

    showQuestion();
}

// start game
shuffle(questions);
showQuestion();
</script>

</body>
</html>